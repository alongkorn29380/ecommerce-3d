# 1. ใช้ Node.js เวอร์ชันเสถียรเป็นฐานในการรัน
FROM node:20-alpine

# 2. กำหนดโฟลเดอร์ทำงานภายในคอนเทนเนอร์
WORKDIR /app

# 3. คัดลอกไฟล์จัดการแพ็กเกจเข้ามาติดตั้งก่อนเพื่อใช้ Cache
COPY package*.json ./

# 4. ติดตั้งโมดูลทั้งหมด (คลีนและเร็วบนสภาพแวดล้อม Linux)
RUN npm install

# 5. คัดลอกโค้ดที่เหลือทั้งหมดในโฟลเดอร์ backend เข้ามา
COPY . .

# 6. เปิดพอร์ตระบุตัวตนแอปพลิเคชัน
EXPOSE 5000

# 7. สั่งสตาร์ทแอปพลิเคชันโดยตรง
CMD ["node", "server.js"]